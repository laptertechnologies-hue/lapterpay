# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Server
PORT=4000

# Outbound email (welcome email, OTP email templates, password reset)
# Leave unset and the backend will log emails to the email_logs table
# instead of actually sending them — everything else keeps working.
# Any standard SMTP provider works (e.g. Resend, Postmark, SendGrid SMTP,
# Gmail with an app password, Mailgun, etc.)
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM="LapterPay <no-reply@lapterpay.com>"
